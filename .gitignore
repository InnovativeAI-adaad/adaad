__pycache__/
*.py[cod]
*.log
.env
.venv/
.envrc
.tmp/
.pytest_cache/
.mypy_cache/

# Data and telemetry
/data/quarantine/*
!/data/quarantine/.gitkeep
/data/adad.sqlite3

# Editor artifacts
*.swp
.DS_Store
.idea/
.vscode/

# Signatures and releases
*.sig
*.zip

# Allow directory keepers
!**/.gitkeep

# Runtime logs (generated; not tracked)
/data/logs/*.jsonl

/reports/metrics.jsonl
/reports/system_dependency_graph.json
/logs/*.log
/logs/*.jsonl
/security/ledger/*.jsonl
!/security/ledger/cryovant_journal.genesis.jsonl
/security/ledger/gate_hash.txt

# Never commit private keys
security/keys/*
!security/keys/.gitkeep
venv/
reports/
data/work/
data/logs/
security/ledger/*.lock
*.lock
runtime/evolution/state/
app/agents/
venv/
reports/
data/work/
data/logs/
security/ledger/*.lock
*.lock
runtime/evolution/state/
app/agents/

# ADAAD governed build agent state
.adaad_agent_state.json
.adaad_operator_contacts.json

# Runtime federation state (generated at runtime)
/federation_state.json

# Runtime generated artifacts (not source)
/data/aponi_command_queue.jsonl
/data/fitness_landscape_state.json
/data/weight_adaptor_state.json
/runtime/lifecycle_states/
/runtime/mcp/proposal_queue.jsonl
/security/ledger/cryovant_journal.tail.json
/security/promotion_manifests/*.json
/security/replay_manifests/
