{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/InnovativeAI-adaad/adaad/schemas/agent_state_schema.json",
  "title": "ADAAD Agent State Schema",
  "description": "Schema for .adaad_agent_state.json — the authoritative runtime state tracker",
  "version": "1.6.0",
  "type": "object",
  "required": [
    "phase",
    "phase_label",
    "active_phase",
    "last_completed_phase",
    "last_innovation",
    "current_version",
    "software_version",
    "version",
    "schema_version",
    "human0_signoffs",
    "completed_milestones",
    "value_checkpoints_reached"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version of this schema"
    },
    "phase": {
      "type": "integer",
      "minimum": 1,
      "description": "Next phase number to execute"
    },
    "phase_label": {
      "type": "string",
      "description": "Human-readable next phase label, e.g. 'Phase 100 — INNOV-15 Agent Reputation Staking'"
    },
    "active_phase": {
      "type": "string",
      "description": "Current execution state description"
    },
    "last_completed_phase": {
      "type": "string",
      "description": "Most recently completed phase label"
    },
    "last_completed_pr": {
      "type": "string",
      "description": "Branch name of last completed PR"
    },
    "last_innovation": {
      "type": "string",
      "pattern": "^INNOV-\\d+$",
      "description": "Most recently shipped innovation ID"
    },
    "current_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "software_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "next_pr": {
      "type": "string",
      "description": "Description of the next expected PR"
    },
    "last_invocation": {
      "type": "string",
      "format": "date",
      "description": "Date of last agent session (YYYY-MM-DD)"
    },
    "blocked_at_gate": {"type": ["string", "null"]},
    "blocked_at_tier": {"type": ["string", "null"]},
    "blocked_reason": {"type": ["string", "null"]},
    "last_gate_results": {
      "type": "object",
      "properties": {
        "tier_0": {"type": "string", "enum": ["pass", "fail", "skip"]},
        "tier_1": {"type": "string", "enum": ["pass", "fail", "skip"]},
        "tier_2": {"type": "string", "enum": ["pass", "fail", "skip"]},
        "tier_3": {"type": "string", "enum": ["pass", "fail", "skip"]}
      }
    },
    "human0_signoffs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["date", "governor", "scope", "session_digest"],
        "properties": {
          "date": {"type": "string", "format": "date"},
          "governor": {"type": "string"},
          "scope": {"type": "string"},
          "session_digest": {"type": "string"},
          "attestation_ref": {"type": "string"},
          "gpg_key": {"type": "string"},
          "tags_signed": {"type": "array", "items": {"type": "string"}},
          "double_human0": {"type": "boolean"}
        }
      }
    },
    "open_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "status"],
        "properties": {
          "id": {"type": "string", "pattern": "^FINDING-\\d+-\\d+$"},
          "title": {"type": "string"},
          "severity": {"type": "string", "enum": ["P0", "P1", "P2", "P3"]},
          "status": {"type": "string", "enum": ["open", "in_progress", "resolved", "runbook_delivered"]},
          "source": {"type": "string"},
          "phase_target": {"type": "string"},
          "resolved_phase": {"type": "string"},
          "resolved_date": {"type": "string"}
        }
      }
    },
    "completed_milestones": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Completed phase milestones, e.g. 'phase100-plan', 'v9.33.0-released'"
    },
    "value_checkpoints_reached": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Fine-grained implementation checkpoints"
    },
    "acse_active": {"type": "boolean"},
    "tife_active": {"type": "boolean"},
    "last_sync_sha": {"type": "string"},
    "last_agent_state_sync_digest": {"type": "string"},
    "pending_evidence_rows": {"type": "array"}
  },
  "additionalProperties": false,
  "_notes": [
    "current_version, software_version, and version MUST all be identical",
    "phase (integer) is the NEXT phase to execute, not the last completed",
    "human0_signoffs is append-only — never remove entries",
    "All three version fields must match VERSION file and pyproject.toml"
  ]
}
