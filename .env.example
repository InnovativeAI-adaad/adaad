# ADAADChat GitHub App — copy to .env and fill in values
# NEVER commit .env

# ── GitHub App identity ─────────────────────────────────────────────────────
GITHUB_APP_ID=3013088
GITHUB_APP_CLIENT_ID=Iv23liYNPdEjUgXwiT8Y

# Set this EXACTLY in the GitHub App settings page → Webhook → Secret
GITHUB_WEBHOOK_SECRET=REPLACE_WITH_YOUR_SECRET

# Private key — download from GitHub App settings → Private keys
ADAAD_GITHUB_KEY_PATH=security/keys/adaadchat.pem
# For cloud: paste the PEM inline (replace newlines with \n)
# ADAAD_GITHUB_KEY_PEM=

# From GitHub App → Install page URL: /installations/XXXXXXXX
ADAAD_GITHUB_APP_ID=3013088
ADAAD_GITHUB_INSTALL_ID=REPLACE_WITH_INSTALLATION_ID

# ── Server ──────────────────────────────────────────────────────────────────
ADAAD_HOST=0.0.0.0
ADAAD_PORT=8080
ADAAD_ENV=production

# ── Governance fallback log ─────────────────────────────────────────────────
ADAAD_GITHUB_AUDIT_LOG=data/github_app_events.jsonl
